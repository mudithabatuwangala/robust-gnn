import torch
import torch.nn.functional as F
from torch.nn import Linear
from torch_geometric.datasets import TUDataset
from torch_geometric.loader import DataLoader
from torch_geometric.nn import GCNConv, global_mean_pool, global_add_pool, global_max_pool
from sklearn.model_selection import train_test_split
import numpy as np
import pandas as pd

# 1. Load Dataset
dataset = TUDataset(root='data/Mutagenicity', name='Mutagenicity')

# 2. Strategic Size-Stratified Split Function
def get_stratified_dataloaders(dataset, seed, batch_size=64):
    # Calculate node counts for stratification
    sizes = [data.num_nodes for data in dataset]
    # Define bins: 0 (<30), 1 (30-50), 2 (>50)
    bins = np.digitize(sizes, [30, 50])
    
    indices = np.arange(len(dataset))
    # Stratify both train and test to ensure large molecules are in both
    train_idx, test_idx = train_test_split(
        indices, test_size=0.2, stratify=bins, random_state=seed
    )
    
    # Further split test_idx into test and val
    test_bins = bins[test_idx]
    val_idx, final_test_idx = train_test_split(
        test_idx, test_size=0.5, stratify=test_bins, random_state=seed
    )

    return (
        DataLoader(dataset[train_idx.tolist()], batch_size=batch_size, shuffle=True),
        DataLoader(dataset[val_idx.tolist()], batch_size=batch_size),
        DataLoader(dataset[final_test_idx.tolist()], batch_size=batch_size),
        dataset[final_test_idx.tolist()] # Return raw test set for size-group analysis
    )

# 3. Flexible GCN Model
class ResearchGCN(torch.nn.Module):
    def __init__(self, hidden_channels, act_type, pool_type):
        super().__init__()
        # Seeding weights: manual_seed here ensures deterministic initialization
        self.conv1 = GCNConv(dataset.num_node_features, hidden_channels)
        self.conv2 = GCNConv(hidden_channels, hidden_channels)
        self.conv3 = GCNConv(hidden_channels, hidden_channels)
        self.lin = Linear(hidden_channels, dataset.num_classes)
        
        self.act_type = act_type
        self.pool_type = pool_type

    def forward(self, x, edge_index, batch):
        # Activation mapping
        act = {'relu': F.relu, 'elu': F.elu, 'leaky': F.leaky_relu}[self.act_type]
        
        x = act(self.conv1(x, edge_index))
        x = act(self.conv2(x, edge_index))
        x = act(self.conv3(x, edge_index))

        # Pooling mapping
        if self.pool_type == 'mean': x = global_mean_pool(x, batch)
        elif self.pool_type == 'sum': x = global_add_pool(x, batch)
        elif self.pool_type == 'max': x = global_max_pool(x, batch)

        return self.lin(x)

# 4. Evaluation Function with Size-Grouping
def evaluate_by_size(model, loader):
    model.eval()
    correct = 0
    size_results = {'small': [0,0], 'medium': [0,0], 'large': [0,0]} # [correct, total]

    for data in loader:
        out = model(data.x, data.edge_index, data.batch)
        pred = out.argmax(dim=1)
        
        # Track accuracy by individual graph size in the batch
        for i in range(len(data.y)):
            num_nodes = (data.batch == i).sum().item()
            label = data.y[i].item()
            is_correct = (pred[i] == label).item()
            
            group = 'small' if num_nodes <= 30 else 'medium' if num_nodes <= 50 else 'large'
            size_results[group][0] += is_correct
            size_results[group][1] += 1
            if is_correct: correct += 1

    accs = {k: (v[0]/v[1] if v[1]>0 else 0) for k, v in size_results.items()}
    return correct / len(loader.dataset), accs

# 5. The Triple-Loop Execution (Act x Pool x Seed)
activations = ['relu', 'elu', 'leaky']
poolings = ['mean', 'sum', 'max']
seeds = [42, 123] # Use more seeds for final report
results = []

for act in activations:
    for pool in poolings:
        print(f"\n--- Running Experiment: {act.upper()} + {pool.upper()} ---")
        
        for seed in seeds:
            torch.manual_seed(seed)
            train_loader, val_loader, test_loader, raw_test = get_stratified_dataloaders(dataset, seed)
            
            model = ResearchGCN(64, act, pool)
            optimizer = torch.optim.Adam(model.parameters(), lr=0.001)
            criterion = torch.nn.CrossEntropyLoss()
            
            # Early Stopping Variables
            best_val_loss = float('inf')
            patience = 15
            trigger = 0

            for epoch in range(1, 101):
                # Train Loop
                model.train()
                for data in train_loader:
                    optimizer.zero_grad()
                    out = model(data.x, data.edge_index, data.batch)
                    loss = criterion(out, data.y)
                    loss.backward()
                    optimizer.step()
                
                # Val Loss for Early Stopping
                model.eval()
                val_loss = 0
                for data in val_loader:
                    v_out = model(data.x, data.edge_index, data.batch)
                    val_loss += criterion(v_out, data.y).item()
                
                if val_loss < best_val_loss:
                    best_val_loss = val_loss
                    trigger = 0
                    torch.save(model.state_dict(), 'best_model.pt')
                else:
                    trigger += 1
                    if trigger >= patience: break
            
            # Final Test Evaluation
            model.load_state_dict(torch.load('best_model.pt'))
            total_acc, group_accs = evaluate_by_size(model, test_loader)
            
            results.append({
                'Activation': act, 'Pooling': pool, 'Seed': seed,
                'Total_Acc': total_acc, 'Small_Acc': group_accs['small'],
                'Med_Acc': group_accs['medium'], 'Large_Acc': group_accs['large']
            })

# 6. View Results as DataFrame
df = pd.DataFrame(results)
summary = df.groupby(['Activation', 'Pooling']).mean().drop(columns='Seed')
print("\n--- FINAL SCIENTIFIC SUMMARY ---")
print(summary)